{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CLANG_TIDY": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Disable optimizations - include debug information.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimize for speed - exclude debug information.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release_without_tests",
      "displayName": "ReleaseWithoutTests",
      "description": "Optimize for speed - exclude debug information (do not build tests).",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "profile",
      "displayName": "Profile",
      "description": "Optimized build with debug symbols for CPU profiling.",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "thread_sanitizer",
      "displayName": "ThreadSanitizer",
      "description": "Thread Sanitizer (Catches Data Races)",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS" : "-fsanitize=thread -g -O1",
        "CMAKE_C_FLAGS": "-fsanitize=thread -g -O1",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "address_sanitizer",
      "displayName": "AddrAndUndefBehavSanitizer",
      "description": "Address and Undefined Behavior Sanitizer (Catches Memory Leaks and Undefined Behavior)",
      "inherits": "debug",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -g -O1 -fno-omit-frame-pointer",
        "CMAKE_C_FLAGS": "-fsanitize=address,undefined -g -O1 -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "BUILD_TESTS": "OFF"
      }
    }
  ]
}